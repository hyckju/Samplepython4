# Copy to .env for local development (do not commit .env)

APP_NAME=secure-fastapi
ENVIRONMENT=production

# Default: docs disabled for safety
ENABLE_DOCS=false

# Optional CORS allowlist (comma-separated)
# CORS_ALLOW_ORIGINS=https://example.com,https://app.example.com

# Required for protected endpoints
# ADMIN_API_TOKEN=replace-with-a-strong-random-token

# Required to store/reveal PII-kind secrets (Fernet key)
# Generate (python):
#   from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
# DATA_ENCRYPTION_KEY=

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
MAX_CONTENT_LENGTH=65536
